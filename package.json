{
  "name": "prova",
  "version": "0.0.1",
  "private": true,
  "description": "Cryptographic receipts for the agentic internet — behavior attestation layer for AI agents on Solana",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml}\" --ignore-path .gitignore",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rimraf node_modules",
    "db:generate": "turbo run db:generate --filter=@prova/db",
    "db:migrate": "turbo run db:migrate --filter=@prova/db",
    "db:studio": "pnpm --filter=@prova/db db:studio",
    "ship": "vercel --prod -y"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "next": "^15.1.6",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
