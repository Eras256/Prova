{
  "name": "@prova/api",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rimraf dist && pnpm --filter=@prova/db build && pnpm --filter=@prova/core build && esbuild src/index.ts --bundle --platform=node --target=node20 --outdir=dist --external:pg --external:pg-native",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.1",
    "@prova/core": "workspace:*",
    "@prova/db": "workspace:*",
    "@sentry/node": "^8.47.0",
    "hono": "^4.6.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@prova/config-typescript": "workspace:*",
    "@types/node": "^22.10.7",
    "esbuild": "^0.28.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
