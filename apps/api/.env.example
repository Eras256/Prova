# Prova API — variables de entorno (copiar a .env, nunca commitear .env)

# Supabase / PostgreSQL
# Transaction pooler (puerto 6543) — para runtime
DATABASE_URL=postgresql://postgres.XXXXXXXXXXXXXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Conexión directa (puerto 5432) — para migraciones Drizzle
DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXXXXXXXX.supabase.co:5432/postgres

PORT=3001
NODE_ENV=development

# Program ID del contrato Prova en Solana
SOLANA_PROGRAM_ID=G11dBAzLQaADtHHM2AZNz3ThCDnkY5nhX3Ujddu1CMM1

# Dirección del treasury para pagos x402
X402_TREASURY_PUBKEY=6mf8TTQvSEEhAcC7uxuiWQn8JWGYFMokEAz8c2acjASK

# Genera con: openssl rand -hex 32
# En Fly.io: fly secrets set ADMIN_SECRET="$(openssl rand -hex 32)" --app prova-api
ADMIN_SECRET=change-me

# Opcional — Sentry error tracking
SENTRY_DSN=
