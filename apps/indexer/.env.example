# Prova Indexer — variables de entorno (copiar a .env, nunca commitear .env)

# Supabase / PostgreSQL
# Transaction pooler (puerto 6543) — para runtime
DATABASE_URL=postgresql://postgres.XXXXXXXXXXXXXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Conexión directa (puerto 5432) — usar si el pooler da "Tenant or user not found"
DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXXXXXXXX.supabase.co:5432/postgres

# Helius — RPC Solana de alta disponibilidad (devnet)
HELIUS_API_KEY=TU_HELIUS_API_KEY
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=TU_HELIUS_API_KEY

# Program ID del contrato Prova en Solana devnet
SOLANA_PROGRAM_ID=G11dBAzLQaADtHHM2AZNz3ThCDnkY5nhX3Ujddu1CMM1

NODE_ENV=development

# Opcional — Sentry error tracking
SENTRY_DSN=
