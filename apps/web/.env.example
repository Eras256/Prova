# Prova Web — variables de entorno (configurar en .env.local o Vercel dashboard)

# ─── Privy (Auth + Embedded Wallets) ─────────────────────────────────────────
# Obtener en: https://dashboard.privy.io → tu app → Settings
NEXT_PUBLIC_PRIVY_APP_ID=TU_PRIVY_APP_ID
PRIVY_APP_SECRET=TU_PRIVY_APP_SECRET
NEXT_PUBLIC_PRIVY_JWKS_ENDPOINT=https://auth.privy.io/api/v1/apps/TU_PRIVY_APP_ID/jwks.json

# ─── Helius (RPC Solana) ──────────────────────────────────────────────────────
# Obtener en: https://dashboard.helius.dev → API Keys
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=TU_HELIUS_API_KEY

# ─── Solana / Programa ────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_PROVA_PROGRAM_ID=G11dBAzLQaADtHHM2AZNz3ThCDnkY5nhX3Ujddu1CMM1

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY
# Settings → Database → Connection string → Transaction pooler (puerto 6543)
DATABASE_URL=postgresql://postgres.XXXXXXXXXXXXXXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Settings → Database → Connection string → Direct connection (puerto 5432)
DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.XXXXXXXXXXXXXXXX.supabase.co:5432/postgres

# ─── API Prova ────────────────────────────────────────────────────────────────
# Producción: https://prova-api.fly.dev  |  Local: http://localhost:3001
NEXT_PUBLIC_PROVA_API_URL=https://prova-api.fly.dev

# ─── x402 Treasury ────────────────────────────────────────────────────────────
NEXT_PUBLIC_X402_TREASURY=6mf8TTQvSEEhAcC7uxuiWQn8JWGYFMokEAz8c2acjASK
