{
  "name": "prova-agent-sdk",
  "version": "0.1.6",
  "description": "Behavior attestation SDK for AI agents on Solana — wrap any agent action in a cryptographic receipt",
  "license": "Apache-2.0",
  "author": "Prova Labs",
  "homepage": "https://www.theprova.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eras256/Prova.git",
    "directory": "packages/sdk-typescript"
  },
  "keywords": [
    "solana",
    "ai-agents",
    "attestation",
    "blockchain",
    "web3",
    "cryptography",
    "ed25519",
    "anchor",
    "prova"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/web3.js": "^1.98.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@prova/config-typescript": "workspace:*",
    "@vitest/coverage-v8": "^2.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
