{
  "extends": "@prova/config-typescript/node",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "resolveJsonModule": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "verbatimModuleSyntax": false,
    "allowImportingTsExtensions": false,
    "noEmit": false
  },
  "include": ["src"]
}
